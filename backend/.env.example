# =================================================================
# Vehicle Center Backend Environment Variables Example
# Copy this file to '.env' and fill in your values.
# =================================================================

# Server Port
PORT=5000

# Environment Mode (development / production)
NODE_ENV=development

# MongoDB Connection URI
# Local MongoDB: mongodb://localhost:27017/car-rental
# Atlas MongoDB: mongodb+srv://<username>:<password>@cluster.mongodb.net/car-rental
MONGO_URI=mongodb://localhost:27017/car-rental

# JSON Web Token (JWT) Configuration
# Use a strong, random key in production
JWT_SECRET=super-secret-dev-key
JWT_EXPIRE=30d

# Frontend Application URL (for CORS and client integration)
FRONTEND_URL=http://localhost:3000

# Default Administrator Credentials (used by scripts/createAdmin.js)
ADMIN_EMAIL=admin@carrental.com
ADMIN_PASSWORD=admin123

# Email Service Configuration (Optional - for Nodemailer booking receipts/notifications)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-email-password-or-app-password
